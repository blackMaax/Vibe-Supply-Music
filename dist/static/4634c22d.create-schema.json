[
  {
    "fields": [
      {
        "initialValue": "Site Settings",
        "hidden": true,
        "name": "internalTitle",
        "type": "string"
      },
      {
        "options": {
          "hotspot": true
        },
        "validation": [
          {
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error"
          }
        ],
        "name": "logo",
        "type": "image",
        "title": "Main Logo"
      },
      {
        "options": {
          "hotspot": true
        },
        "description": "A version of the logo for use on dark backgrounds.",
        "name": "logoWhite",
        "type": "image",
        "title": "White/Inverted Logo (Optional)"
      },
      {
        "description": "Recommended: .ico or .png, square dimensions (e.g., 32x32, 64x64).",
        "name": "favicon",
        "type": "image"
      },
      {
        "name": "contactEmail",
        "type": "string"
      },
      {
        "name": "contactPhone",
        "type": "string",
        "title": "Contact Phone (Optional)"
      },
      {
        "of": [
          {
            "fields": [
              {
                "options": {
                  "list": [
                    {
                      "title": "Instagram",
                      "value": "instagram"
                    },
                    {
                      "title": "Facebook",
                      "value": "facebook"
                    },
                    {
                      "title": "Twitter / X",
                      "value": "twitter"
                    },
                    {
                      "title": "LinkedIn",
                      "value": "linkedin"
                    },
                    {
                      "title": "YouTube",
                      "value": "youtube"
                    },
                    {
                      "title": "TikTok",
                      "value": "tiktok"
                    },
                    {
                      "title": "Other",
                      "value": "other"
                    }
                  ]
                },
                "validation": [
                  {
                    "rules": [
                      {
                        "flag": "valid",
                        "constraint": [
                          "instagram",
                          "facebook",
                          "twitter",
                          "linkedin",
                          "youtube",
                          "tiktok",
                          "other"
                        ]
                      },
                      {
                        "flag": "presence",
                        "constraint": "required"
                      }
                    ],
                    "level": "error"
                  }
                ],
                "name": "platform",
                "type": "string"
              },
              {
                "validation": [
                  {
                    "rules": [
                      {
                        "flag": "presence",
                        "constraint": "required"
                      },
                      {
                        "flag": "uri",
                        "constraint": {
                          "options": {
                            "scheme": [
                              "/^http$/",
                              "/^https$/"
                            ],
                            "allowRelative": false,
                            "relativeOnly": false,
                            "allowCredentials": false
                          }
                        }
                      }
                    ],
                    "level": "error"
                  }
                ],
                "name": "url",
                "type": "url",
                "title": "URL"
              }
            ],
            "type": "object",
            "name": "socialLink"
          }
        ],
        "name": "socialLinks",
        "type": "array",
        "title": "Social Media Links"
      },
      {
        "description": "Default title for pages if not set specifically. Keep it concise (50-60 characters).",
        "name": "defaultSeoTitle",
        "type": "string",
        "title": "Default SEO Title"
      },
      {
        "rows": 3,
        "description": "Default meta description for pages. Aim for 150-160 characters.",
        "name": "defaultSeoDescription",
        "type": "text",
        "title": "Default SEO Description"
      },
      {
        "description": "Default image for social media sharing (e.g., when a link to your site is posted). Recommended aspect ratio 1.91:1 (e.g., 1200x630px).",
        "name": "defaultSeoImage",
        "type": "image",
        "title": "Default SEO Share Image"
      },
      {
        "description": "E.g., © YEAR Vibe Supply. All rights reserved.",
        "name": "footerText",
        "type": "string"
      }
    ],
    "name": "siteSettings",
    "type": "document"
  },
  {
    "fields": [
      {
        "initialValue": "Homepage",
        "hidden": true,
        "name": "title",
        "type": "string"
      },
      {
        "fields": [
          {
            "of": [
              {
                "options": {
                  "hotspot": true
                },
                "fields": [
                  {
                    "description": "Describe this image for accessibility and SEO.",
                    "name": "alt",
                    "type": "string",
                    "title": "Image Alt Text / Name"
                  }
                ],
                "type": "image"
              }
            ],
            "name": "images",
            "type": "array",
            "title": "Hero Images"
          }
        ],
        "name": "mainHero",
        "type": "object",
        "title": "Main Hero Section"
      },
      {
        "fields": [
          {
            "options": {
              "hotspot": true
            },
            "description": "Logo image displayed in the About Vibe Supply card",
            "name": "logo",
            "type": "image",
            "title": "Section Logo"
          },
          {
            "description": "Intro text displayed above the package features list.",
            "name": "featuresIntro",
            "type": "string",
            "title": "Features Intro Text"
          },
          {
            "description": "Bullet points describing what is included in the package.",
            "of": [
              {
                "fields": [
                  {
                    "name": "text",
                    "type": "string",
                    "title": "Feature Text"
                  }
                ],
                "type": "object"
              }
            ],
            "name": "features",
            "type": "array",
            "title": "Package Features"
          },
          {
            "description": "Text shown at the bottom of the About Vibe Supply card (e.g., Elevating events since 2015)",
            "name": "footer",
            "type": "string",
            "title": "Section Footer Text"
          },
          {
            "options": {
              "hotspot": true
            },
            "fields": [
              {
                "description": "Describe this image for accessibility and SEO.",
                "name": "imageAlt",
                "type": "string",
                "title": "Image Alt Text / SEO Title"
              },
              {
                "description": "Title displayed on the image card (e.g., Unforgettable Experiences)",
                "name": "imageTitle",
                "type": "string",
                "title": "Image Card Title"
              },
              {
                "description": "Subtitle displayed on the image card (e.g., Let's create magical moments for your special event)",
                "name": "imageSubtitle",
                "type": "string",
                "title": "Image Card Subtitle"
              }
            ],
            "name": "image",
            "type": "image",
            "title": "Section Image"
          }
        ],
        "name": "aboutVibeSupply",
        "type": "object",
        "title": "About Vibe Supply Section"
      }
    ],
    "name": "homepage",
    "type": "document"
  }
]