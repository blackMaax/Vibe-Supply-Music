[
  {
    "fields": [
      {
        "description": "The name of your site, usually your company/brand name.",
        "name": "title",
        "type": "string",
        "title": "Site Title",
        "fieldset": "branding"
      },
      {
        "options": {
          "hotspot": true
        },
        "fields": [
          {
            "description": "Important for SEO and accessibility.",
            "name": "alt",
            "type": "string",
            "title": "Alt text"
          }
        ],
        "name": "logo",
        "type": "image",
        "title": "Site Logo",
        "fieldset": "branding"
      },
      {
        "options": {
          "hotspot": true
        },
        "description": "A version of the logo for use on dark backgrounds.",
        "fields": [
          {
            "description": "Important for SEO and accessibility.",
            "name": "alt",
            "type": "string",
            "title": "Alt text"
          }
        ],
        "name": "logoWhite",
        "type": "image",
        "title": "White/Inverted Logo",
        "fieldset": "branding"
      },
      {
        "description": "Recommended: .ico or .png, square dimensions (e.g., 32x32, 64x64).",
        "name": "favicon",
        "type": "image",
        "fieldset": "branding"
      },
      {
        "description": "Describe your site for search engines and social media.",
        "name": "description",
        "type": "text",
        "title": "Site Description",
        "fieldset": "seo"
      },
      {
        "description": "Add keywords that describe your site.",
        "of": [
          {
            "type": "string"
          }
        ],
        "name": "keywords",
        "type": "array",
        "fieldset": "seo"
      },
      {
        "options": {
          "hotspot": true
        },
        "description": "Used for social media cards when no image is added.",
        "name": "defaultOgImage",
        "type": "image",
        "title": "Default OG Image",
        "fieldset": "seo"
      },
      {
        "description": "Primary contact email address for the site.",
        "name": "contactEmail",
        "type": "string",
        "fieldset": "contact"
      },
      {
        "description": "Primary contact phone number for the site.",
        "name": "contactPhone",
        "type": "string",
        "fieldset": "contact"
      },
      {
        "fields": [
          {
            "description": "Typically your company/brand name for the copyright notice.",
            "name": "copyrightName",
            "type": "string",
            "title": "Copyright Holder Name"
          },
          {
            "description": "Text displayed at the very bottom of the footer (e.g., © YEAR Company Name. All rights reserved.). If blank, a default might be used.",
            "name": "footerText",
            "type": "string",
            "title": "Custom Footer Text"
          }
        ],
        "name": "footer",
        "type": "object",
        "title": "Footer Content",
        "fieldset": "footerConfig"
      },
      {
        "of": [
          {
            "fields": [
              {
                "options": {
                  "list": [
                    {
                      "title": "Facebook",
                      "value": "facebook"
                    },
                    {
                      "title": "Instagram",
                      "value": "instagram"
                    },
                    {
                      "title": "Twitter (X)",
                      "value": "twitter"
                    },
                    {
                      "title": "LinkedIn",
                      "value": "linkedin"
                    },
                    {
                      "title": "YouTube",
                      "value": "youtube"
                    },
                    {
                      "title": "TikTok",
                      "value": "tiktok"
                    },
                    {
                      "title": "Pinterest",
                      "value": "pinterest"
                    },
                    {
                      "title": "Snapchat",
                      "value": "snapchat"
                    },
                    {
                      "title": "WhatsApp",
                      "value": "whatsapp"
                    }
                  ]
                },
                "validation": [
                  {
                    "rules": [
                      {
                        "flag": "valid",
                        "constraint": [
                          "facebook",
                          "instagram",
                          "twitter",
                          "linkedin",
                          "youtube",
                          "tiktok",
                          "pinterest",
                          "snapchat",
                          "whatsapp"
                        ]
                      },
                      {
                        "flag": "presence",
                        "constraint": "required"
                      }
                    ],
                    "level": "error"
                  }
                ],
                "name": "platform",
                "type": "string"
              },
              {
                "validation": [
                  {
                    "rules": [
                      {
                        "flag": "presence",
                        "constraint": "required"
                      },
                      {
                        "flag": "uri",
                        "constraint": {
                          "options": {
                            "scheme": [
                              "/^http$/",
                              "/^https$/"
                            ],
                            "allowRelative": false,
                            "relativeOnly": false,
                            "allowCredentials": false
                          }
                        }
                      }
                    ],
                    "level": "error"
                  }
                ],
                "name": "url",
                "type": "url",
                "title": "URL"
              }
            ],
            "type": "object"
          }
        ],
        "name": "socialLinks",
        "type": "array",
        "fieldset": "social"
      }
    ],
    "fieldsets": [
      {
        "name": "branding",
        "title": "Branding & Identity",
        "options": {
          "collapsible": true,
          "collapsed": false
        }
      },
      {
        "name": "seo",
        "title": "SEO & Metadata",
        "options": {
          "collapsible": true,
          "collapsed": false
        }
      },
      {
        "name": "contact",
        "title": "Contact Information",
        "options": {
          "collapsible": true,
          "collapsed": false
        }
      },
      {
        "name": "footerConfig",
        "title": "Footer Configuration",
        "options": {
          "collapsible": true,
          "collapsed": false
        }
      },
      {
        "name": "social",
        "title": "Social Media Links",
        "options": {
          "collapsible": true,
          "collapsed": false
        }
      }
    ],
    "name": "siteSettings",
    "type": "document"
  },
